# Test-only env. Vitest loads this (mode = "test") ahead of .env.
# The MSW handlers in tests/handlers.ts intercept http://localhost:3000,
# so the API base URL must match exactly (127.0.0.1 is a different origin
# to MSW and would fall through to onUnhandledRequest: 'error').
VITE_API_URL=http://localhost:3000
